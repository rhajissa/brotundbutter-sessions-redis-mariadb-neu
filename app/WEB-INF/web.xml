<?xml version="1.0" encoding="UTF-8"?>
<web-app>

  <display-name>SWE 3 Mini App</display-name>

  <context-param>
    <param-name>redispassword</param-name>
    <param-value>REDISPASSWORD</param-value>
  </context-param>
  <context-param>
    <param-name>redisserver</param-name>
    <param-value>REDISSERVER</param-value>
  </context-param>

  <listener>
    <listener-class>hbv.web.MyContextListener</listener-class>
  </listener>

  <servlet>
    <servlet-name>loginServlet</servlet-name>
    <servlet-class>hbv.web.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>loginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>logoutServlet</servlet-name>
    <servlet-class>hbv.web.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>logoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <!-- Usecases: Ausleihe & Rückgabe & Session-Status -->
  <servlet>
    <servlet-name>sessionStatusServlet</servlet-name>
    <servlet-class>hbv.web.SessionStatusServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>sessionStatusServlet</servlet-name>
    <url-pattern>/session-status</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>borrowServlet</servlet-name>
    <servlet-class>hbv.web.BorrowServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>borrowServlet</servlet-name>
    <url-pattern>/borrow</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>returnServlet</servlet-name>
    <servlet-class>hbv.web.ReturnServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>returnServlet</servlet-name>
    <url-pattern>/return</url-pattern>
  </servlet-mapping>



  <filter> 
    <filter-name>myfilter</filter-name>
    <filter-class>hbv.web.MyFilter</filter-class> 
    <async-supported>true</async-supported> 
  </filter> 

  <filter-mapping> 
    <filter-name>myfilter</filter-name>
    <url-pattern>/*</url-pattern> 
  </filter-mapping> 

</web-app>  
